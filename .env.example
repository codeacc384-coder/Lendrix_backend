# DigitalOcean managed Postgres requires sslmode=require (NOT prefer)
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname?sslmode=require

# Must be a strong random string — app will REFUSE to start with the default value
SECRET_KEY=your_super_secret_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS: comma-separated list of allowed frontend origins
# Use * only for local dev — always set explicit origins in production
ALLOWED_ORIGINS=https://yourfrontend.com,https://www.yourfrontend.com

UTHO_ENDPOINT_URL=https://bucket-lendrixtest.innoida.utho.io/
UTHO_ACCESS_KEY=your_access_key
UTHO_SECRET_KEY=your_secret_key
BUCKET_NAME=lendrix

# Required only for migrate_missing_tables.py
DB_HOST=your_db_host
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSLMODE=require
DB_TARGET_NAME=LV_ProcessPolicies_DB
DB_SOURCE_NAME=lendrixtest1

# Required only for seed_admin.py
SEED_ANGEL_EMAIL=angel@yourdomain.com
SEED_ANGEL_PHONE=+919999999901
SEED_ANGEL_PASSWORD=YourStrongPassword1!
SEED_VCS_EMAIL=vcs@yourdomain.com
SEED_VCS_PHONE=+919999999902
SEED_VCS_PASSWORD=YourStrongPassword2!
